{
  "name": "jg-site",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "start": "vite preview --host 0.0.0.0",
    "preview": "vite preview",
    "routes:generate": "tsr generate",
    "typecheck": "bun run routes:generate && tsc --noEmit",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@tanstack/router-plugin": "1.167.35",
    "clsx": "2.1.1",
    "lucide-react": "1.14.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@netlify/vite-plugin-tanstack-start": "1.3.12",
    "@playwright/test": "1.60.0",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/router-cli": "1.166.43",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.3.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "8.0.12",
    "vitest": "4.1.6"
  }
}
